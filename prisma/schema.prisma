/**
 * @file prisma/schema.prisma
 * @description Definisi model database (Schema) untuk sistem SIPASI.
 * Mendefinisikan tabel Users, SuratMasuk, DocumentFile, AuditLog, 
 * dan relasi antar entitas yang digunakan oleh Prisma ORM.
 * 
 * Mendukung 7 jenis surat: Undangan, Surat Masuk, Surat Tugas,
 * Surat Keluar, SK Direktur, Perjanjian, Peraturan Direktur.
 */
// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN_STAFF
  AGENDARIS
  DIREKTUR
  KABAG
  KASUBAG
}

enum DocumentStatus {
  DRAFT
  MENUNGGU_REVIEW_AGENDARIS
  PERLU_REVISI
  DIJADWALKAN_KE_DIREKTUR
  MENUNGGU_KEPUTUSAN_DIREKTUR
  DIPROSES_DIREKTUR
  KEPUTUSAN_DIREKTUR_SELESAI
  MENUNGGU_PENGAMBILAN_STAFF
  MENUNGGU_SCAN_FINAL
  MENUNGGU_ARSIP_ADMIN
  ARSIP_FINAL_TERSIMPAN
}

enum DecisionType {
  DISETUJUI
  DITOLAK
  REVISI
  DISPOSISI
}

enum FileType {
  DRAFT
  SCAN_MASUK
  FINAL_SCAN
  ATTACHMENT
}

enum ReviewStatus {
  DITERUSKAN
  DIKEMBALIKAN
}

enum SuratType {
  MASUK
  KELUAR
}

enum UndanganMedia {
  ONLINE
  OFFLINE
}

// 7 Jenis Surat/Dokumen yang dikelola SIPASI
enum DocumentType {
  UNDANGAN
  SURAT_MASUK
  SURAT_TUGAS
  SURAT_KELUAR
  SK_DIREKTUR
  PERJANJIAN
  PERATURAN_DIREKTUR
}

// Undangan bisa internal atau external
enum UndanganType {
  INTERNAL
  EXTERNAL
}

// Kategori keperluan dokumen (diperluas)
enum DocumentCategory {
  UNDANGAN
  PEMBELIAN
  KERJASAMA
  KEPEGAWAIAN
  KEUANGAN
  PERIZINAN
  PENGADAAN
  HUKUM
  TEKNIK
  DLL
}

// ─────────────────────────────────────────────
//  USERS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  divisi       String?
  bagian       String?
  title        String?  // Gelar (mis: S.T., M.Kom.)
  image        String?  // Path ke foto profil
  isActive     Boolean  @default(true) @map("is_active")
  
  // Tanda tangan & paraf (base64 atau path ke file gambar)
  signature    String?  // TTD penuh
  paraf        String?  // Versi kecil TTD
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  suratMasukCreated SuratMasuk[]       @relation("SuratMasukCreator")
  documentReviews   DocumentReview[]
  directorDecisions DirectorDecision[]
  archivesCreated   Archive[]
  auditLogs         AuditLog[]
  uploadedFiles     DocumentFile[]
  jadwalDirekturs   JadwalDirekturs[]
  undanganPenerima  UndanganPenerima[]
  disposisiDari     LembarDisposisi[]  @relation("DisposisiDari")
  disposisiKe       LembarDisposisi[]  @relation("DisposisiKe")
  statusTimeline    StatusTimeline[]   @relation("TimelineChangedBy")

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────
//  SURAT / DOKUMEN UTAMA
//  Menyimpan semua 7 jenis surat dalam 1 tabel
//  dengan field `documentType` sebagai pembeda.
// ─────────────────────────────────────────────

model SuratMasuk {
  id              String         @id @default(cuid())
  nomorSurat      String         @unique @map("nomor_surat")
  nomorAgenda     String?        @map("nomor_agenda")
  perihal         String
  deskripsi       String?
  tujuan          String?
  asalSurat       String?        @map("asal_surat")
  tanggalSurat    DateTime       @map("tanggal_surat")
  tanggalTerima   DateTime       @default(now()) @map("tanggal_terima")
  currentStatus   DocumentStatus @default(DRAFT) @map("current_status")
  currentHolder   String?          @map("current_holder")
  category        DocumentCategory @default(DLL)
  isVisible       Boolean          @default(true) @map("is_visible")
  createdById     String         @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Jenis dokumen (7 tipe)
  documentType    DocumentType     @default(SURAT_MASUK) @map("document_type")

  // Tanggal instruksi & penyelesaian (diisi Direktur)
  tanggalInstruksi    DateTime?   @map("tanggal_instruksi")
  tanggalPenyelesaian DateTime?   @map("tanggal_penyelesaian")

  // Relations
  createdBy       User               @relation("SuratMasukCreator", fields: [createdById], references: [id])
  files           DocumentFile[]
  reviews         DocumentReview[]
  decisions       DirectorDecision[]
  archive         Archive?
  auditLogs       AuditLog[]
  statusTimeline  StatusTimeline[]
  jadwalDirekturs JadwalDirekturs[]
  disposisi       LembarDisposisi[]
  undangan        Undangan?

  @@index([currentStatus])
  @@index([createdById])
  @@index([nomorSurat])
  @@index([documentType])
  @@map("surat_masuk")
}

// ─────────────────────────────────────────────
//  DOCUMENT FILES
// ─────────────────────────────────────────────

model DocumentFile {
  id           String   @id @default(cuid())
  suratMasukId String   @map("surat_masuk_id")
  fileType     FileType @map("file_type")
  fileName     String   @map("file_name")
  filePath     String   @map("file_path")
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type")
  uploadedById String   @map("uploaded_by")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  // Relations
  suratMasuk SuratMasuk @relation(fields: [suratMasukId], references: [id], onDelete: Cascade)
  uploadedBy User       @relation(fields: [uploadedById], references: [id])

  @@index([suratMasukId])
  @@index([fileType])
  @@map("document_files")
}

// ─────────────────────────────────────────────
//  DOCUMENT REVIEWS (Agendaris)
// ─────────────────────────────────────────────

model DocumentReview {
  id           String       @id @default(cuid())
  suratMasukId String       @map("surat_masuk_id")
  reviewedById String       @map("reviewed_by")
  reviewNote   String?      @map("review_note")
  reviewStatus ReviewStatus @map("review_status")
  reviewedAt   DateTime     @default(now()) @map("reviewed_at")

  // Relations
  suratMasuk SuratMasuk @relation(fields: [suratMasukId], references: [id], onDelete: Cascade)
  reviewedBy User       @relation(fields: [reviewedById], references: [id])

  @@index([suratMasukId])
  @@map("document_reviews")
}

// ─────────────────────────────────────────────
//  JADWAL KIRIM KE DIREKTUR
// ─────────────────────────────────────────────

model JadwalDirekturs {
  id           String    @id @default(cuid())
  suratMasukId String    @map("surat_masuk_id")
  createdById  String    @map("created_by")
  jadwalKirim  DateTime  @map("jadwal_kirim") // Tanggal & jam kirim
  isUrgen      Boolean   @default(false) @map("is_urgen")
  isSent       Boolean   @default(false) @map("is_sent")
  sentAt       DateTime? @map("sent_at")
  catatan      String?
  createdAt    DateTime  @default(now()) @map("created_at")

  suratMasuk SuratMasuk @relation(fields: [suratMasukId], references: [id], onDelete: Cascade)
  createdBy  User       @relation(fields: [createdById], references: [id])

  @@index([suratMasukId])
  @@index([jadwalKirim])
  @@map("jadwal_direkturs")
}

// ─────────────────────────────────────────────
//  DIRECTOR DECISIONS
// ─────────────────────────────────────────────

model DirectorDecision {
  id                 String       @id @default(cuid())
  suratMasukId       String       @map("surat_masuk_id")
  directorId         String       @map("director_id")
  decisionType       DecisionType @map("decision_type")
  decisionNote       String?      @map("decision_note")
  
  // Data for Barcode
  tempat             String?      @map("tempat")
  tanggalTandaTangan DateTime?    @map("tanggal_tanda_tangan")
  parafDirektur      String?      @map("paraf_direktur") // Base64

  // Tanggal instruksi (wajib diisi Direktur)
  tanggalInstruksi   DateTime?    @map("tanggal_instruksi")

  // Batal tanda tangan — skip auto-sign barcode
  batalTandaTangan   Boolean      @default(false) @map("batal_tanda_tangan")
  
  decidedAt          DateTime     @default(now()) @map("decided_at")

  suratMasuk SuratMasuk @relation(fields: [suratMasukId], references: [id], onDelete: Cascade)
  director   User       @relation(fields: [directorId], references: [id])

  @@index([suratMasukId])
  @@map("director_decisions")
}

// ─────────────────────────────────────────────
//  LEMBAR DISPOSISI
// ─────────────────────────────────────────────

model LembarDisposisi {
  id           String   @id @default(cuid())
  suratMasukId String   @map("surat_masuk_id")
  dariId       String   @map("dari_id")   // agendaris/direktur yang membuat
  keId         String?  @map("ke_id")     // opsional — user penerima (jika ada)
  jabatanKe    String?  @map("jabatan_ke") // label jabatan penerima (diisi Direktur)
  instruksi    String?  // diisi Direktur
  keterangan   String?  // catatan tambahan
  
  // Data for Barcode
  tempat             String?  @map("tempat")
  tanggalTandaTangan DateTime? @map("tanggal_tanda_tangan")
  parafDariId        String?  @map("paraf_dari_id")

  // Tanggal instruksi & penyelesaian (diisi Direktur)
  tanggalInstruksi    DateTime? @map("tanggal_instruksi")
  tanggalPenyelesaian DateTime? @map("tanggal_penyelesaian")
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  suratMasuk SuratMasuk @relation(fields: [suratMasukId], references: [id], onDelete: Cascade)
  dari       User       @relation("DisposisiDari", fields: [dariId], references: [id])
  ke         User?      @relation("DisposisiKe", fields: [keId], references: [id])

  @@index([suratMasukId])
  @@map("lembar_disposisi")
}

// ─────────────────────────────────────────────
//  UNDANGAN
// ─────────────────────────────────────────────

model Undangan {
  id           String        @id @default(cuid())
  suratMasukId String        @unique @map("surat_masuk_id")
  hari         String        // Senin, Selasa, dst
  tanggal      DateTime
  jam          String        // "08:00"
  tempat       String
  media        UndanganMedia @default(OFFLINE)
  dresscode    String?
  catatanLain  String?       @map("catatan_lain")
  deadline     DateTime      // Deadline kehadiran/konfirmasi
  googleCalId  String?       @map("google_cal_id")

  // Tipe undangan: Internal atau External
  undanganType     UndanganType @default(INTERNAL) @map("undangan_type")
  pengirimExternal String?      @map("pengirim_external") // Nama instansi/pengirim luar
  kontakExternal   String?      @map("kontak_external")   // Nomor kontak pengirim

  createdAt    DateTime      @default(now()) @map("created_at")

  suratMasuk SuratMasuk       @relation(fields: [suratMasukId], references: [id], onDelete: Cascade)
  penerima   UndanganPenerima[]

  @@map("undangan")
}

model UndanganPenerima {
  id         String  @id @default(cuid())
  undanganId String  @map("undangan_id")
  userId     String  @map("user_id")
  sudahBaca  Boolean @default(false) @map("sudah_baca")

  undangan Undangan @relation(fields: [undanganId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([undanganId, userId])
  @@map("undangan_penerima")
}

// ─────────────────────────────────────────────
//  ARCHIVES
// ─────────────────────────────────────────────

model Archive {
  id             String   @id @default(cuid())
  suratMasukId   String   @unique @map("surat_masuk_id")
  archivedById   String   @map("archived_by")
  serverLocation String?  @map("server_location")
  bulan          Int      // 1-12
  tahun          Int
  archivedAt     DateTime @default(now()) @map("archived_at")
  notes          String?

  suratMasuk SuratMasuk @relation(fields: [suratMasukId], references: [id], onDelete: Cascade)
  archivedBy User       @relation(fields: [archivedById], references: [id])

  @@index([bulan, tahun])
  @@map("archives")
}

// ─────────────────────────────────────────────
//  AUDIT LOGS
// ─────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  suratMasukId String?  @map("surat_masuk_id")
  action       String
  description  String?
  metadata     Json?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id])
  suratMasuk SuratMasuk? @relation(fields: [suratMasukId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([suratMasukId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
//  STATUS TIMELINE
// ─────────────────────────────────────────────

model StatusTimeline {
  id           String         @id @default(cuid())
  suratMasukId String         @map("surat_masuk_id")
  fromStatus   DocumentStatus? @map("from_status")
  toStatus     DocumentStatus @map("to_status")
  changedById  String         @map("changed_by")
  notes        String?
  createdAt    DateTime       @default(now()) @map("created_at")

  suratMasuk SuratMasuk @relation(fields: [suratMasukId], references: [id], onDelete: Cascade)
  changedBy  User       @relation("TimelineChangedBy", fields: [changedById], references: [id])

  @@index([suratMasukId])
  @@map("status_timeline")
}
